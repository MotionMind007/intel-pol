APP_KEY=

# Used by Docker Compose. Generate with:
# cd backend && php artisan key:generate --show

# Environment
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost

# Database (REQUIRED - no defaults for security)
DB_DATABASE=political_intelligence
DB_USERNAME=
DB_PASSWORD=

# Redis (optional password, recommended for production)
REDIS_PASSWORD=

# Internal service token for AI Service communication (REQUIRED)
# Generate a strong random token: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# FastAPI timeout in seconds
FASTAPI_TIMEOUT=300

# Nginx exposed port
NGINX_PORT=8080
